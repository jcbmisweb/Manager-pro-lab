{
  "entities": {
    "Usuario": {
      "title": "Usuario",
      "description": "Usuario del sistema",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nombre": { "type": "string" },
        "correo": { "type": "string" },
        "rol": { "type": "string", "enum": ["admin", "profesor", "alumno"] },
        "estado": { "type": "string", "enum": ["activo", "bloqueado", "suspendido", "eliminado"] },
        "aulaId": { "type": "string" }
      },
      "required": ["id", "nombre", "correo", "rol", "estado"]
    },
    "Aula": {
      "title": "Aula",
      "description": "Aula o clase de laboratorio",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nombre": { "type": "string" },
        "profesorId": { "type": "string" }
      },
      "required": ["id", "nombre", "profesorId"]
    },
    "Project": {
      "title": "Project",
      "description": "Student project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "block": { "type": "string", "enum": ["A", "B", "C"] },
        "title": { "type": "string" },
        "objectives": { "type": "array", "items": { "type": "string" } },
        "technicalData": { "type": "object" },
        "infographicUrl": { "type": "string" }
      },
      "required": ["id", "block", "title", "objectives", "technicalData", "infographicUrl"]
    },
    "NotebookEntry": {
      "title": "NotebookEntry",
      "description": "Student notebook entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "date": { "type": "string" },
        "notes": { "type": "string" },
        "photoUrl": { "type": "string" }
      },
      "required": ["id", "projectId", "date", "notes"]
    },
    "Mensaje": {
      "title": "Mensaje",
      "description": "Mensaje de chat",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "emisorId": { "type": "string" },
        "receptorId": { "type": "string" },
        "mensaje": { "type": "string" },
        "fecha": { "type": "string" },
        "leido": { "type": "boolean" }
      },
      "required": ["id", "emisorId", "receptorId", "mensaje", "fecha", "leido"]
    },
    "IESConfig": {
      "title": "IESConfig",
      "description": "Configuración institucional del IES",
      "type": "object",
      "properties": {
        "nombre": { "type": "string" },
        "logo": { "type": "string" }
      },
      "required": ["nombre", "logo"]
    }
  },
  "firestore": {
    "/usuarios/{userId}": {
      "schema": { "$ref": "#/entities/Usuario" },
      "description": "Colección de usuarios"
    },
    "/aulas/{aulaId}": {
      "schema": { "$ref": "#/entities/Aula" },
      "description": "Colección de aulas"
    },
    "/projects/{projectId}": {
      "schema": { "$ref": "#/entities/Project" },
      "description": "Colección de proyectos"
    },
    "/projects/{projectId}/notebookEntries/{entryId}": {
      "schema": { "$ref": "#/entities/NotebookEntry" },
      "description": "Colección de entradas de cuaderno para un proyecto"
    },
    "/mensajes/{mensajeId}": {
      "schema": { "$ref": "#/entities/Mensaje" },
      "description": "Colección de mensajes"
    },
    "/settings/iesConfig": {
      "schema": { "$ref": "#/entities/IESConfig" },
      "description": "Documento de configuración institucional"
    }
  }
}
